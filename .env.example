# OutEye Edu 环境变量模板
#
# 官方运行方式：Docker Compose + Nginx（Docker-first）
# 1. 复制本文件为 .env
# 2. 填写所有“必填”项
# 3. 在 outeye-edu/ 目录执行 docker compose up -d --build
#
# 本文件主要服务于 Docker Compose。
# 如果你要本地直跑 backend/frontend，请参考下方“本地开发补充变量”说明。

# ==================== Docker-first：基础设施与应用配置 ====================

# PostgreSQL（必填）
POSTGRES_DB=outeye_edu
POSTGRES_USER=outeye
POSTGRES_PASSWORD=change-this-postgres-password

# Redis（必填）
REDIS_PASSWORD=change-this-redis-password

# 应用安全密钥（必填）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-64-char-hex-secret
JWT_SECRET_KEY=replace-with-a-second-64-char-hex-secret

# LLM / RAG（必填）
LLM_API_KEY=replace-with-your-llm-api-key
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
EMBEDDING_MODEL=bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
QDRANT_COLLECTION=outeye_knowledge

# Wiki 挂载路径（主机路径，Docker Compose 会把它挂到容器内 /app/OutEye-Wiki）
# 默认假设目录结构如下：
# outeye3.0/
# ├── OutEye-Wiki/
# └── outeye-edu/
WIKI_HOST_PATH=../OutEye-Wiki

# 前端公开地址
# Docker-first 本地运行请保持为 http://localhost
# 如果部署到服务器，请改为你的公网域名，例如 https://demo.example.com
NEXT_PUBLIC_API_URL=http://localhost

# 应用元信息 / 日志
APP_NAME=OutEye Edu
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=logs/outeye.log

# ==================== 可选：本地开发补充变量（非 Docker-first） ====================
# 以下变量仅在你绕过 Docker、直接运行 backend/frontend 时需要。
# 不建议把它们和 Docker-first 模式混用。

# backend 直跑时可在 backend/.env 中配置：
# DATABASE_URL=postgresql+asyncpg://outeye:password@localhost:5432/outeye_edu
# REDIS_URL=redis://:password@localhost:6379/0
# QDRANT_URL=http://localhost:6333
# WIKI_DATA_PATH=../OutEye-Wiki

# frontend 直跑时可在 frontend/.env.local 中配置：
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== 可选：OCR / 第三方服务 ====================
# ALIYUN_OCR_ACCESS_KEY_ID=
# ALIYUN_OCR_ACCESS_KEY_SECRET=
# ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
# MIMO_API_KEY=
# MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# ==================== 可选：管理员信息 ====================
# ADMIN_EMAIL=admin@example.com
