# OutEye Edu 1.0 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 安全配置（必需） ====================
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-at-least-32-characters-long
JWT_SECRET_KEY=your-jwt-secret-key-at-least-32-characters-long

# ==================== 数据库配置（必需） ====================
# Neon 数据库连接字符串
DATABASE_URL=postgresql+asyncpg://user:password@host/database?sslmode=require

# ==================== Redis 配置（必需） ====================
REDIS_URL=redis://localhost:6379/0

# ==================== AI 模型配置（必需） ====================
LLM_API_KEY=your_deepseek_api_key_here
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ==================== Mimo API 配置（可选） ====================
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_URL=https://token-plan-cn.xiaomimimo.com/anthropic

# ==================== Embedding 模型配置 ====================
EMBEDDING_MODEL=bge-large-zh-v1.5

# ==================== Qdrant 配置 ====================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=outeye_knowledge

# ==================== 前端配置 ====================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== 应用配置 ====================
DEBUG=false
APP_NAME=OutEye Edu
APP_VERSION=1.0.0

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/outeye.log

# ==================== 管理员配置（可选） ====================
ADMIN_EMAIL=admin@example.com
